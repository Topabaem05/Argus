# Nvidia NIM API key (required for live LLM mode)
# Get your key from: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=your-key-here
KSSIM_LLM_API_KEY=your-key-here

# Hugging Face cache directory (optional)
KSSIM_HF_CACHE_DIR=

# PageIndex API key (optional, for RAG grounding)
KSSIM_PAGEINDEX_API_KEY=

# Output directory (optional)
KSSIM_OUTPUT_DIR=outputs